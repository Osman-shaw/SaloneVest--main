# SaloneVest Monolithic Deployment Configuration
# Copy this to .env and fill in your values

# Environment
NODE_ENV=production
NETWORK=devnet

# Database
MONGO_ROOT_USER=admin
# Required for docker-compose: use a long random value (not committed to git).
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Smart Contract
PROGRAM_ID=YOUR_PROGRAM_ID_HERE
SECRET_KEY=YOUR_SECRET_KEY_HERE

# API Configuration
API_PORT=5000
API_HOST=backend
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Optional: For SSL certificates
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
