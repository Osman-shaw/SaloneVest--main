# SaloneVest monolithic (Docker) — copy to .env at repo root
#
# For local dev, prefer split envs (same Peeap SLE rate in both when using Peeap):
#   - backend/.env   → use backend/.env.example (SLE_USDC_RATE, PEEAP_SECRET_KEY, MONGODB_URI, …)
#   - frontend/.env.local → use frontend/.env.example (NEXT_PUBLIC_*, PEEAP public key, …)
#
# Copy this to .env and fill in your values

# Environment
NODE_ENV=production
NETWORK=devnet

# Database
MONGO_ROOT_USER=admin
# Required for docker-compose: use a long random value (not committed to git).
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Smart Contract
PROGRAM_ID=YOUR_PROGRAM_ID_HERE
SECRET_KEY=YOUR_SECRET_KEY_HERE

# API: comma-separated for CORS + websockets (browser Origin must match)
FRONTEND_URL=http://localhost,http://localhost:3000
API_PORT=5000
API_HOST=backend

# Frontend (baked at `next build`; with nginx on :80 use the public host, not backend:5000)
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
