# =============================================================================
# BACKEND (this file)  —  use backend/.env locally (do not commit .env)
# PAIR with: frontend/.env.local for Peeap (same SLE rate in both)
# =============================================================================
# STEPS (do in order)
# 1) Copy:  copy .env.example .env   (Windows)   /   cp .env.example .env
# 2) Set SLE_USDC_RATE (e.g. 25) — MUST match frontend NEXT_PUBLIC_SLE_USDC_RATE exactly.
# 3) Set PEEAP_SECRET_KEY=sk_xxx (server only; never in frontend, never NEXT_PUBLIC_).
# 4) Set MONGODB_URI, JWT_SECRET, FRONTEND_URL (comma-separated for CORS + Socket.io).
# 5) Restart the backend (pnpm run dev or docker) after any .env change; redeploy in production.
# =============================================================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/salonevest

# Server
PORT=5000
NODE_ENV=development

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta

# CORS + Socket.io (comma-separated; every browser Origin that hits the API)
FRONTEND_URL=http://localhost:3000,http://localhost,https://your-frontend.example.com

# --- Peeap (SLE) — business logic: USDC reserved = SLE / rate ---
# Same numeric value as frontend NEXT_PUBLIC_SLE_USDC_RATE (e.g. both 25)
SLE_USDC_RATE=25

# Server-only: webhooks + future server-side Peeap API (never expose to the browser)
PEEAP_SECRET_KEY=

# Security
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
