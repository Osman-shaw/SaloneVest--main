# =============================================================================
# FRONTEND (this file)  —  copy to .env.local in THIS folder; Next reads .env.local
# PAIR with: backend/.env for DB/API + Peeap secret (secret stays on backend only)
# =============================================================================
# STEPS (do in order)
# 1) Copy:  copy .env.example .env.local   (Windows)   /   cp .env.example .env.local
# 2) Set NEXT_PUBLIC_PEEAP_PUBLIC_KEY=pk_live_xxx or pk_test_xxx (client / SDK only).
# 3) Set NEXT_PUBLIC_SLE_USDC_RATE — MUST match backend SLE_USDC_RATE exactly (e.g. both 25).
# 4) Set NEXT_PUBLIC_API_URL to your Express API (e.g. http://localhost:5000 in dev).
# 5) Restart Next (pnpm dev) after .env.local changes; production: set env in host and rebuild.
# =============================================================================
# Never put PEEAP_SECRET_KEY here. Never use NEXT_PUBLIC_ for any secret.
# =============================================================================

# API
NEXT_PUBLIC_API_URL=http://localhost:5000

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Peeap (SLE) — public key only; same SLE rate number as backend SLE_USDC_RATE
NEXT_PUBLIC_PEEAP_PUBLIC_KEY=
NEXT_PUBLIC_PEEAP_BASE_URL=https://api.peeap.com
NEXT_PUBLIC_SLE_USDC_RATE=25
